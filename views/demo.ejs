<!DOCTYPE html>
<html>
<head>
  <title>gMatch Demo</title>
  <style>
    body { font-family: Arial; padding: 40px; }
    select, button { padding: 8px; margin-right: 10px; }
    .results { margin-top: 30px; }
  </style>
</head>
<body>

<h2>gMatch Demo</h2>

<label>Strategy:</label>
<select id="strategy">
  <option value="WeightedHybridStrategy" selected>
    WeightedHybridStrategy (Default)
  </option>
  <option value="AvailabilityOnlyStrategy">
    AvailabilityOnlyStrategy
  </option>
  <option value="SkillBalancedStrategy">
    SkillBalancedStrategy
  </option>
</select>

<button onclick="generate()">Generate Teams</button>

<div class="results" id="results"></div>

<script>
async function generate() {
  const strategy = document.getElementById("strategy").value;

  const res = await fetch("/api/generate", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ strategy })
  });

  const data = await res.json();
  const container = document.getElementById("results");
  container.innerHTML = "<h3>Generated Teams</h3>";

  data.teams.forEach((team, index) => {
    const names = team.map(s => s.name).join(" + ");
    container.innerHTML += `<p>Group ${index + 1}: ${names}</p>`;
  });
}
</script>

</body>
</html>
